      }
    },
    {
      "cell_type": "code",
      "source": [
        "df = df.drop_duplicates(subset=['title'], keep='first').copy()\n",
        "print(f\"Dimensi Dataset Setelah Duplikat Dihapus: {df.shape[0]} baris\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "PwG70HA72Rp0",
        "outputId": "31af2491-3711-42e9-b2fe-dc0af38e9933"
      },
      "execution_count": 17,
      "outputs": [
        {
          "output_type": "stream",
