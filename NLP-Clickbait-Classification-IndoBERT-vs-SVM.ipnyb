    {
      "cell_type": "code",
      "source": [
        "def prediksi_judul_baru(text):\n",
        "    text_clean = preprocessing_indobert(text)\n",
        "    inputs = tokenizer(text_clean, return_tensors=\"pt\", padding=True, truncation=True, max_length=64).to(device)\n",
        "    model.eval()\n",
        "    with torch.no_grad():\n",
        "        outputs = model(**inputs)\n",
        "    prediction = torch.argmax(outputs.logits, dim=-1).item()\n",
        "    return \"CLICKBAIT\" if prediction == 1 else \"NON-CLICKBAIT\"\n",
        "\n",
        "# Contoh Pengujian\n",
        "berita_uji = [\n",
        "    \"Mengejutkan! Artis Papan Atas Ini Lakukan Hal Ini Di Rumahnya Kemarin Malam!\",\n",
        "    \"Kemensos Salurkan Rp 7,3 M bagi Korban Kerusuhan Sosial di Papua.\",\n",
        "    \"Bikin Geleng Kepala, Segini Jumlah Harta Kekayaan Milik Pejabat X.\"\n",
        "]\n",
        "\n",
        "for teks in berita_uji:\n",
        "    hasil = prediksi_judul_baru(teks)\n",
        "    print(f\"Input Judul : \\\"{teks}\\\"\")\n",
        "    print(f\"Hasil Model -> {hasil}\\n\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "KufX9H6o_yvN",
        "outputId": "be8f174c-a82e-4543-a0d2-eebf7155a319"
      },
      "execution_count": 66,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Input Judul : \"Mengejutkan! Artis Papan Atas Ini Lakukan Hal Ini Di Rumahnya Kemarin Malam!\"\n",
            "Hasil Model -> CLICKBAIT\n",
            "\n",
            "Input Judul : \"Kemensos Salurkan Rp 7,3 M bagi Korban Kerusuhan Sosial di Papua.\"\n",
            "Hasil Model -> NON-CLICKBAIT\n",
            "\n",
            "Input Judul : \"Bikin Geleng Kepala, Segini Jumlah Harta Kekayaan Milik Pejabat X.\"\n",
            "Hasil Model -> CLICKBAIT\n",
            "\n"
          ]
        }
      ]
