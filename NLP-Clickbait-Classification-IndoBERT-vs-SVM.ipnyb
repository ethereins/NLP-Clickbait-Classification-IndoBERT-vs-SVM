    {
      "cell_type": "code",
      "source": [
        "import plotly.graph_objects as go\n",
        "from plotly.subplots import make_subplots\n",
        "\n",
        "df['char_length'] = df['title'].apply(lambda x: len(str(x)))\n",
        "df['word_count'] = df['title'].apply(lambda x: len(str(x).split()))\n",
        "\n",
        "fig = make_subplots(\n",
        "    rows=1, cols=2,\n",
        "    subplot_titles=('<b>Distribusi Panjang Karakter</b>', '<b>Distribusi Jumlah Kata</b>')\n",
        ")\n",
        "\n",
        "unique_labels = sorted(df['label'].unique())\n",
        "\n",
        "for label in unique_labels:\n",
        "    df_label = df[df['label'] == label]\n",
        "    fig.add_trace(\n",
        "        go.Box(\n",
        "            x=df_label['label'],\n",
        "            y=df_label['char_length'],\n",
        "            name=f'Label {label}',\n",
        "            marker_color='blue' if label == 0 else 'red',\n",
        "            showlegend=False\n",
        "        ),\n",
        "        row=1, col=1\n",
        "    )\n",
        "\n",
        "for label in unique_labels:\n",
        "    df_label = df[df['label'] == label]\n",
        "    fig.add_trace(\n",
        "        go.Box(\n",
        "            x=df_label['label'],\n",
        "            y=df_label['word_count'],\n",
        "            name=f'Label {label}',\n",
        "            marker_color='blue' if label == 0 else 'red',\n",
        "            showlegend=False\n",
        "        ),\n",
        "        row=1, col=2\n",
        "    )\n",
        "\n",
        "fig.update_layout(\n",
        "    title_text='<b>Analisis Distribusi Teks Berdasarkan Label</b>',\n",
        "    title_x=0.5,\n",
        "    template='plotly_white',\n",
        "    width=1700,\n",
        "    height=700\n",
        ")\n",
        "\n",
        "fig.update_xaxes(title_text='Label', row=1, col=1)\n",
        "fig.update_xaxes(title_text='Label', row=1, col=2)\n",
        "fig.update_yaxes(title_text='Panjang Karakter', row=1, col=1)\n",
        "fig.update_yaxes(title_text='Jumlah Kata', row=1, col=2)\n",
        "\n",
        "fig.show()"
      ],
