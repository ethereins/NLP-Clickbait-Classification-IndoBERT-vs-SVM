            "Dimensi Dataset Setelah Duplikat Dihapus: 14970 baris\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "def preprocessing_indobert(text):\n",
        "    if not isinstance(text, str):\n",
        "        return \"\"\n",
        "    text = text.lower()\n",
        "    text = \" \".join(text.split())\n",
        "    return text"
      ],
      "metadata": {
        "id": "lbEwUzVl1cS6"
      },
      "execution_count": 25,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "IndoBERT hanya butuh Case Folding dan pembersihan spasi berlebih.\n",
        "\n",
        "Tanda baca (!, ?) dan angka dibiarkan karena IndoBERT memahami maknanya."
      ],
      "metadata": {
        "id": "PKbFQBXq-gMd"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "df['cleaned_title'] = df['title'].apply(preprocessing_indobert)\n",
        "print(\"Contoh Perubahan Hasil Praproses (Setelah Perbaikan):\")\n",
        "for i in range(5):\n",
        "    print(f\"Sebelum: {df['title'].iloc[i]}\")\n",
        "    print(f\"Sesudah: {df['cleaned_title'].iloc[i]}\\n\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "SuRmjCS77I3m",
        "outputId": "ef8d1aac-6cef-43d5-885d-e9f6f588b56b"
      },
      "execution_count": 101,
      "outputs": [
        {
          "output_type": "stream",
