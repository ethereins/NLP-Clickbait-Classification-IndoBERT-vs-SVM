    {
      "cell_type": "markdown",
      "source": [
        "Akurasinya turun dan loss-nya naik di epoch terakhir karena model mulai mengalami gejala Overfitting setelah epoch 1 karena kapasitas dataset yang sudah jenuh dipelajari. Namun, kode sudah sangat aman karena mengaktifkan fungsi load_best_model_at_end=True. Jadi, model akhir yang disimpan dan mengevaluasi data testing otomatis diambil dari versi terbaiknya, yaitu Epoch 1."
      ],
      "metadata": {
        "id": "gZlkgTqHCFy6"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from transformers import EarlyStoppingCallback\n",
        "\n",
        "# Atur ulang parameter training agar lebih stabil dan kebal overfitting\n",
        "training_args = TrainingArguments(\n",
        "    output_dir=\"./results\",\n",
        "    learning_rate=1e-5,               # Diturunkan dari 2e-5 agar belajar lebih teliti\n",
        "    per_device_train_batch_size=16,\n",
        "    per_device_eval_batch_size=16,\n",
        "    gradient_accumulation_steps=2,    # Mengakumulasikan gradient agar update bobot lebih stabil\n",
        "    num_train_epochs=5,               # Naikkan ke 5 karena lr kecil, tapi dikontrol Early Stopping\n",
        "    weight_decay=0.01,\n",
        "    warmup_ratio=0.1,\n",
        "    eval_strategy=\"epoch\",\n",
        "    save_strategy=\"epoch\",\n",
        "    load_best_model_at_end=True,\n",
        "    metric_for_best_model=\"eval_loss\",\n",
        "    greater_is_better=False,\n",
        "    logging_steps=10,\n",
        "    report_to=\"none\"\n",
        ")\n",
        "\n",
        "trainer = Trainer(\n",
        "    model=model,\n",
        "    args=training_args,\n",
        "    train_dataset=train_dataset,\n",
        "    eval_dataset=test_dataset,\n",
        "    compute_metrics=compute_metrics,\n",
        "    callbacks=[EarlyStoppingCallback(early_stopping_patience=1)]\n",
        ")\n",
        "\n",
        "print(\"Memulai proses training optimasi IndoBERT...\")\n",
        "trainer.train()"
      ],
