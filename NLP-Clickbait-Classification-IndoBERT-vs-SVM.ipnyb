        "<a href=\"https://colab.research.google.com/github/ethereins/NLP-Clickbait-Classification-IndoBERT-vs-SVM/blob/main/NLP-Clickbait-Classification-IndoBERT-vs-SVM.ipnyb\" target=\"_parent\"><img src=\"https://colab.research.google.com/assets/colab-badge.svg\" alt=\"Open In Colab\"/></a>"
