            "Sesudah: terkait mayat bayi mengenaskan di tangerang, seorang pria ditangkap polisi\n",
            "\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "df_bert = pd.DataFrame({\n",
        "    'text': df['cleaned_title'],\n",
        "    'label': df['label_score'].astype(int)\n",
        "})"
      ],
      "metadata": {
        "id": "pOlQwPVr9jym"
      },
      "execution_count": 26,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# **PEMODELAN**"
      ],
      "metadata": {
        "id": "kzYbiRZh-vUo"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "df_train, df_test = train_test_split(df_bert, test_size=0.2, random_state=42, stratify=df_bert['label'])\n",
        "print(f\"Data Latih: {len(df_train)} sampel | Data Uji: {len(df_test)} sampel\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "FSJzUkfm6TDs",
        "outputId": "6f20d4dd-0b4c-4ccb-9cf1-b992d5e1eee6"
      },
      "execution_count": 27,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Data Latih: 11976 sampel | Data Uji: 2994 sampel\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "print(\"Memuat IndoBERT Tokenizer dari Hugging Face...\")\n",
        "tokenizer = BertTokenizer.from_pretrained(\"indobenchmark/indobert-base-p1\")\n",
        "\n",
        "def tokenize_function(examples):\n",
        "    return tokenizer(examples['text'], padding=\"max_length\", truncation=True, max_length=64)\n",
        "\n",
        "# Mengubah format ke Dataset Hugging Face agar sesuai dengan pipeline training\n",
        "train_dataset = Dataset.from_pandas(df_train.reset_index(drop=True))\n",
        "test_dataset = Dataset.from_pandas(df_test.reset_index(drop=True))\n",
        "\n",
        "print(\"Mengonversi teks menjadi token numerik IndoBERT...\")\n",
        "train_dataset = train_dataset.map(tokenize_function, batched=True)\n",
        "test_dataset = test_dataset.map(tokenize_function, batched=True)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
