    {
      "cell_type": "markdown",
      "source": [
        "Pelatihan kedua (Model Optimasi) menggunakan learning rate 1e-5 dan mekanisme Early Stopping memberikan hasil yang jauh lebih baik secara kualitas. Pendekatan ini berhasil menyembuhkan gejala overfitting ekstrem yang sempat terjadi pada model awal (di mana validation loss sempat melonjak ke 0.556). Meskipun nilai akurasi murni di Epoch 2 pada model kedua tertulis 0.8296 (sekitar 82.9%, beda tipis sekali dengan model pertama yang 83.6%), secara arsitektur internal, bobot model pada Epoch 2 di pelatihan kedua jauh lebih matang (robust) dan stabil karena proses belajarnya dituntun secara perlahan menggunakan learning rate yang lebih kecil (1e-5) dan gradient accumulation, menjadikannya model yang paling andal dan aman untuk diimplementasikan pada data riil."
      ],
      "metadata": {
        "id": "wzeXzUkEKDmq"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import plotly.graph_objects as go\n",
        "from plotly.subplots import make_subplots\n",
        "\n",
        "data_awal = {\n",
        "    'epoch': [1, 2, 3],\n",
        "    'loss': [0.391948, 0.256206, 0.166060],\n",
        "    'eval_loss': [0.386806, 0.414805, 0.556042]\n",
        "}\n",
        "\n",
        "data_optimasi = {\n",
        "    'epoch': [1, 2, 3],\n",
        "    'loss': [0.733508, 0.552971, 0.611430],\n",
        "    'eval_loss': [0.403985, 0.393571, 0.429648]\n",
        "}\n",
        "\n",
        "df_1 = pd.DataFrame(data_awal)\n",
        "df_2 = pd.DataFrame(data_optimasi)\n",
        "\n",
        "fig = make_subplots(\n",
        "    rows=1, cols=2,\n",
        "    subplot_titles=('<b>Model Awal (Overfitting)</b>', '<b>Model Optimasi (Stabil)</b>')\n",
        ")\n",
        "\n",
        "fig.add_trace(\n",
        "    go.Scatter(x=df_1['epoch'], y=df_1['loss'], mode='lines+markers',\n",
        "               name='Train Loss (Awal)', line=dict(color='blue', width=2)),\n",
        "    row=1, col=1\n",
        ")\n",
        "fig.add_trace(\n",
        "    go.Scatter(x=df_1['epoch'], y=df_1['eval_loss'], mode='lines+markers',\n",
        "               name='Val Loss (Awal)', line=dict(color='red', width=2)),\n",
        "    row=1, col=1\n",
        ")\n",
        "\n",
        "fig.add_trace(\n",
        "    go.Scatter(x=df_2['epoch'], y=df_2['loss'], mode='lines+markers',\n",
        "               name='Train Loss (Opt)', line=dict(color='teal', width=2)),\n",
        "    row=1, col=2\n",
        ")\n",
        "fig.add_trace(\n",
        "    go.Scatter(x=df_2['epoch'], y=df_2['eval_loss'], mode='lines+markers',\n",
        "               name='Val Loss (Opt)', line=dict(color='orange', width=2)),\n",
        "    row=1, col=2\n",
        ")\n",
        "\n",
        "fig.update_layout(\n",
        "    title_text='<b>Perbandingan Kurva Performa IndoBERT</b>',\n",
        "    title_x=0.5,\n",
        "    template='plotly_white',\n",
        "    hovermode='x unified',\n",
        "    width=1200,\n",
        "    height=500,\n",
        "    showlegend=True\n",
        ")\n",
        "\n",
        "fig.update_xaxes(title_text='Epoch', tickmode='array', tickvals=[1, 2, 3], row=1, col=1)\n",
        "fig.update_xaxes(title_text='Epoch', tickmode='array', tickvals=[1, 2, 3], row=1, col=2)\n",
        "fig.update_yaxes(title_text='Loss', row=1, col=1)\n",
        "fig.update_yaxes(title_text='Loss', row=1, col=2)\n",
        "\n",
        "fig.show()"
      ],
